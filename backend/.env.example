# --- LLM (Groq) ---
# Groq API key. Get one at https://console.groq.com/keys
# Free tier: 30 RPM / 14 400 RPD for llama-3.3-70b-versatile.
GROQ_API_KEY=

# Optional overrides — take precedence over the Groq defaults
# (use these to pin a specific model or route through a proxy).
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# --- Auth + cloud sync ---
# Google OAuth Web client ID — used to verify ID tokens issued to the Flutter
# app. The mobile and desktop clients are bound to this same project, so
# tokens issued for any of them carry this Web client ID as the `aud` claim
# when `serverClientId` is configured on the client side.
GOOGLE_OAUTH_WEB_CLIENT_ID=

# HMAC secret for our session JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Filesystem path for the SQLite database. On Fly.io point this at a mounted
# volume (e.g. /data/noetica.db); locally any writable path works.
NOETICA_DB_PATH=./data/noetica.db

# --- HTTP ---
CORS_ORIGINS=http://localhost:8080
LOG_LEVEL=INFO
